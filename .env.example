# ⚠️ REQUIRED: Your Telegram user ID — get from @userinfobot
# Without this the bot won't recognize you as owner!
OWNER_ID=123456789

# Telegram API credentials — get from https://my.telegram.org/apps
BOT_TOKEN=123456:ABCdef...
TG_API_ID=12345678
TG_API_HASH=abc123def456...
TG_PHONE_PART1=+1
TG_PHONE_PART2=5551234567

# Paths
DB_PATH=./data/tracker.db

# API token — use a random string for /getall, /stats endpoints
# If not set, BOT_TOKEN is used as fallback
API_TOKEN=changeme

# API host — change to 0.0.0.0 for external access (NOT recommended)
API_HOST=127.0.0.1
API_PORT=8091
